# Bot Configuration
BOT_USERNAME=mybot

# Slack (optional)
# Single-workspace mode (hardcoded bot token):
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_SIGNING_SECRET=your-signing-secret
# Multi-workspace mode (OAuth - use instead of SLACK_BOT_TOKEN):
# SLACK_CLIENT_ID=your-client-id
# SLACK_CLIENT_SECRET=your-client-secret
# SLACK_ENCRYPTION_KEY=your-32-byte-hex-key  # optional, encrypts stored tokens

# Microsoft Teams (optional)
# TEAMS_APP_ID=your-app-id
# TEAMS_APP_PASSWORD=your-app-password

# Google Chat (optional)
# GOOGLE_CHAT_CREDENTIALS={"type":"service_account",...}

# Discord (optional)
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_PUBLIC_KEY=your-public-key

# Facebook Messenger (optional)
# FACEBOOK_APP_SECRET=your-app-secret
# FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token
# FACEBOOK_VERIFY_TOKEN=your-verify-token

# GitHub (optional) — via Vercel Connect (https://vercel.com/docs/connect)
# Set to your GitHub connector UID; the adapter resolves a short-lived
# installation token at runtime and verifies Connect-forwarded webhooks with a
# Vercel OIDC token (no GitHub App private key or webhook secret to store).
# GITHUB_CONNECTOR=github/your-connector
# Requires VERCEL_OIDC_TOKEN in the environment — run `vercel env pull` locally.
# Strongly recommended (required on serverless): the bot's numeric user id.
# In Connect mode the adapter can't auto-detect it, so without this it can't
# recognize its own comments and will reply to itself in a loop across
# function instances. Find it (no auth needed) with:
#   curl -s 'https://api.github.com/users/<your-app-slug>[bot]'
# GITHUB_BOT_USER_ID=123456

# Linear (optional) - use API key, access token, client credentials, or multi-tenant OAuth installs
# API key authentication (simplest):
# LINEAR_API_KEY=lin_api_xxxxxxxxxxxx
# OR pre-obtained OAuth access token:
# LINEAR_ACCESS_TOKEN=lin_oauth_xxxxxxxxxxxx
# OR single-tenant client credentials:
# LINEAR_CLIENT_CREDENTIALS_CLIENT_ID=your-client-id
# LINEAR_CLIENT_CREDENTIALS_CLIENT_SECRET=your-client-secret
# LINEAR_CLIENT_CREDENTIALS_SCOPES=read,write,comments:create,issues:create
# OR multi-tenant OAuth installs:
# LINEAR_CLIENT_ID=your-client-id
# LINEAR_CLIENT_SECRET=your-client-secret
# LINEAR_REDIRECT_URI=https://your-domain.com/api/linear/install/callback
# Optional inbound webhook mode:
# LINEAR_MODE=comments
# Use LINEAR_MODE=agent-sessions for app-actor installs
# Required for either auth method:
# LINEAR_WEBHOOK_SECRET=your-webhook-secret
# LINEAR_BOT_USERNAME=my-bot

# Redis (for production state persistence)
# REDIS_URL=redis://localhost:6379
