    {
      "name": "Zernio",
      "value": "zernio",
      "package": "@zernio/chat-sdk-adapter",
      "factoryFn": "createZernioAdapter",
      "typeName": "ZernioAdapter",
      "category": "Messaging Platforms",
      "envVars": [
        {
          "name": "ZERNIO_API_KEY",
          "description": "Zernio API key",
